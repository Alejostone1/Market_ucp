# ─── Base de datos (Neon PostgreSQL) ───────────────────────────────────────────
# Pooler URL — usado por la aplicación en producción/Vercel
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&channel_binding=require"

# Direct URL — usado por prisma db push / migraciones
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DBNAME?sslmode=require"

# ─── NextAuth ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL="https://tu-dominio.vercel.app"
NEXTAUTH_SECRET="genera-un-secreto-seguro-aqui"

# ─── Email (opcional) ──────────────────────────────────────────────────────────
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""

# ─── Aplicación ────────────────────────────────────────────────────────────────
NODE_ENV="production"
NEXT_PUBLIC_APP_NAME="UCP Marketplace"
NEXT_PUBLIC_APP_URL="https://tu-dominio.vercel.app"
